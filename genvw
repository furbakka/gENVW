#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
TARGET="$SCRIPT_DIR/genvw.sh"

if [[ ! -f "$TARGET" ]]; then
  printf 'gENVW launcher error: missing target script: %s\n' "$TARGET" >&2
  exit 1
fi

if [[ ! -x "$TARGET" ]]; then
  printf 'gENVW launcher error: target script is not executable: %s\n' "$TARGET" >&2
  exit 1
fi

exec "$TARGET" "$@"
